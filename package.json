{
  "name": "sentry-lighthouse",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hosted Lighthouse lab for sentry-javascript. Accepts prebuilt test-app bundles from CI, runs Lighthouse on stable hardware, exposes results via a dashboard.",
  "type": "module",
  "engines": {
    "node": ">=22.22.0 <23"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "start": "node --env-file-if-exists=.env src/supervisor.js",
    "start:server": "node --env-file-if-exists=.env src/server.js",
    "start:publisher": "node --env-file-if-exists=.env src/publisher.js",
    "dev": "node --env-file-if-exists=.env --watch src/supervisor.js",
    "dev:server": "node --env-file-if-exists=.env --watch src/server.js",
    "dev:publisher": "node --env-file-if-exists=.env --watch src/publisher.js",
    "migrate": "node --env-file-if-exists=.env src/db/migrate.js",
    "fixture:upload": "node --env-file-if-exists=.env scripts/upload-fixture.js",
    "docker:build": "docker build --build-arg GIT_SHA=$(git rev-parse --short HEAD) -t sentry-lighthouse .",
    "docker:run": "docker run --rm -p 8080:8080 -v $(pwd)/data:/data --env-file .env sentry-lighthouse"
  },
  "dependencies": {
    "@fastify/basic-auth": "6.2.0",
    "@fastify/bearer-auth": "10.1.0",
    "@fastify/multipart": "9.0.3",
    "@fastify/static": "8.2.0",
    "@lhci/cli": "0.15.1",
    "@sentry/node": "10.53.1",
    "ajv": "8.17.1",
    "better-sqlite3": "11.10.0",
    "fastify": "5.6.1",
    "fastify-plugin": "5.0.1",
    "pino": "9.13.1",
    "playwright-chromium": "1.56.0",
    "tar": "7.5.1",
    "ulid": "3.0.1"
  },
  "devDependencies": {
    "pino-pretty": "13.1.2"
  }
}
