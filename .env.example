# --- Required ---

# Bearer token CI uses to upload builds. Generate with `openssl rand -hex 32`.
UPLOAD_TOKEN=replace-me

# --- Optional ---

# Fastify listen port. Northflank sets this automatically; leave unset there.
PORT=8080

# Persistent storage root. In Docker this is the mounted volume.
DATA_DIR=./data

# If both are set, the dashboard (and read-only API) require HTTP basic auth.
# Leave unset for a public dashboard.
# DASHBOARD_USERNAME=admin
# DASHBOARD_PASSWORD=replace-me

# Max bytes per uploaded bundle. Default 100 MB — bundles ship without
# node_modules now, so this is plenty. Raise if you're shipping fat SSR
# bundles with the .next/ build output.
# MAX_UPLOAD_BYTES=104857600

# Wall-clock ceiling for the optional per-cell installCmd (e.g.
# `pnpm install --frozen-lockfile`).
# INSTALL_TIMEOUT_MS=300000

# How long to keep build tarballs before the cleanup loop removes them.
# Reports + metrics stay forever; only the raw bundles are cleaned.
# BUNDLE_RETENTION_DAYS=7

# pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Optional: override the Chrome binary Lighthouse uses. If unset we use
# Playwright's bundled Chromium (`playwright install chromium`).
# CHROME_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome

# Number of Lighthouse runs per cell. Google recommends 5; lower for local
# smoke tests (this is what `pnpm run fixture:upload` runs against).
# LIGHTHOUSE_NUM_RUNS=5

# --- Sentry publisher ---

# DSN of the Sentry project this lab publishes metrics into. If unset, the
# publisher process still runs but emits a warning and ships nothing — useful
# for local dev where you want the worker but not the network egress.
# SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>

# Sentry environment tag. Defaults to NODE_ENV.
# SENTRY_ENVIRONMENT=production

# How often the publisher polls SQLite for completed-but-unpublished cells.
# PUBLISHER_POLL_MS=10000
