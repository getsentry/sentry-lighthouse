# --- Required ---

# Bearer token CI uses to upload builds. Generate with `openssl rand -hex 32`.
UPLOAD_TOKEN=replace-me

# --- Optional ---

# Fastify listen port. Northflank sets this automatically; leave unset there.
PORT=8080

# Persistent storage root. In Docker this is the mounted volume.
DATA_DIR=./data

# If both are set, the dashboard (and read-only API) require HTTP basic auth.
# Leave unset for a public dashboard.
# DASHBOARD_USERNAME=admin
# DASHBOARD_PASSWORD=replace-me

# Max bytes per uploaded bundle. Default 600 MB.
# MAX_UPLOAD_BYTES=629145600

# How long to keep build tarballs before the cleanup loop removes them.
# Reports + metrics stay forever; only the raw bundles are cleaned.
# BUNDLE_RETENTION_DAYS=7

# pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Optional: override the Chrome binary Lighthouse uses. If unset we use
# Playwright's bundled Chromium (`playwright install chromium`).
# CHROME_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
